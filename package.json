{
  "name": "gopeed-folder-downloader",
  "version": "1.0.0",
  "private": true,
  "description": "Gopeed extension that resolves an HTTP directory listing into a folder resource so a whole folder tree can be downloaded at once, structure preserved.",
  "type": "module",
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack --mode production --watch",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "check": "bun run typecheck && bun run test"
  },
  "keywords": [
    "gopeed",
    "gopeed-extension",
    "folder",
    "directory",
    "downloader"
  ],
  "author": "sidhanthapoddar99",
  "license": "MIT",
  "homepage": "https://github.com/sidhanthapoddar99/gopeed-extension-folder-downloader#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sidhanthapoddar99/gopeed-extension-folder-downloader.git"
  },
  "bugs": {
    "url": "https://github.com/sidhanthapoddar99/gopeed-extension-folder-downloader/issues"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@gopeed/types": "^1.6.1",
    "@types/bun": "^1.1.0",
    "babel-loader": "^9.1.3",
    "gopeed": "^1.6.1",
    "gopeed-polyfill-webpack-plugin": "^1.0.6",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0"
  }
}
